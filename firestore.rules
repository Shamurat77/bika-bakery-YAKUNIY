rules_version = '2';

// Bika Bakery — ishga tushirish (launch) uchun xavfsizlik qoidalari.
// O'rnatish: Firebase konsol -> Firestore Database -> Rules -> shu matnni qo'yib -> Publish.
// Diqqat: hozir test-mode qoidalari turibdi (muddati bilan). Launch'dan OLDIN shuni qo'ying.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Filial xodimi yoki admin
    function isStaff() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "filial"];
    }

    // Mahsulotlar: hamma o'qiydi (katalog ochiq), faqat admin yozadi
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Foydalanuvchi profillari: har kim faqat o'zinikini, admin hammani ko'radi.
    // Oddiy foydalanuvchi o'z roli(role)ni o'zgartira olmaydi.
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.role == "mijoz";
      allow update: if isAdmin() ||
        (signedIn() && request.auth.uid == uid &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    // Buyurtmalar: mijoz o'zinikini yaratadi/ko'radi, admin hammasini boshqaradi.
    // Mijoz faqat baho (rating, ratingComment) maydonlarini o'zgartira oladi.
    match /orders/{id} {
      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid;
      allow read: if isStaff() ||
        (signedIn() && resource.data.customerId == request.auth.uid);
      allow update: if isAdmin() ||
        (isStaff() &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status'])) ||
        (signedIn() && resource.data.customerId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['rating', 'ratingComment']));
      allow delete: if isAdmin();
    }

    // Ombor: faqat admin
    match /inventory/{id} {
      allow read, write: if isAdmin();
    }
    match /inventory_moves/{id} {
      allow read, write: if isAdmin();
    }
  }
}
